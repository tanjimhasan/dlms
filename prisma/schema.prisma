generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  STOCK
}

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String
  role      Role       @default(STOCK)
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  customers Customer[]
  products  Product[]
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

model Customer {
  id        String         @id @default(uuid())
  name      String
  phone     String
  area      String
  status    CustomerStatus @default(ACTIVE)
  totalDue  Decimal        @default(0) @db.Decimal(12, 2)
  createdBy String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [createdBy], references: [id])
}

enum ProductUnit {
  PCS
  KG
  LITER
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Product {
  id               String      @id @default(uuid())
  name             String      @unique
  sku              String?
  description      String?
  categoryId       String?
  brand            String?
  tags             String?
  actualPrice      Decimal     @db.Decimal(12, 2)
  sellingPrice     Decimal     @db.Decimal(12, 2)
  trackInventory   Boolean     @default(false)
  minimumStockLevel Int?
  unit             ProductUnit @default(PCS)
  createdBy        String
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  category         Category?   @relation(fields: [categoryId], references: [id])
  user             User        @relation(fields: [createdBy], references: [id])
}
