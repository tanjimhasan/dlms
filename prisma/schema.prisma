generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  STOCK
}

model User {
  id              String     @id @default(uuid())
  name            String
  email           String     @unique
  password        String
  role            Role       @default(STOCK)
  active          Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  customers       Customer[]
  products        Product[]
  createdOrders   Order[]    @relation("CreatedOrders")
  reviewedOrders  Order[]    @relation("ReviewedOrders")
  shipments       Shipment[]
  payments        Payment[]
  stockIns        StockIn[]
  damages         Damage[]
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

model Customer {
  id        String         @id @default(uuid())
  name      String
  phone     String
  area      String
  status    CustomerStatus @default(ACTIVE)
  totalDue  Decimal        @default(0) @db.Decimal(12, 2)
  createdBy String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [createdBy], references: [id])
  orders    Order[]
}

enum ProductUnit {
  PCS
  KG
  LITER
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Product {
  id                String       @id @default(uuid())
  name              String       @unique
  sku               String?
  description       String?
  categoryId        String?
  brand             String?
  tags              String?
  actualPrice       Decimal      @db.Decimal(12, 2)
  sellingPrice      Decimal      @db.Decimal(12, 2)
  trackInventory    Boolean      @default(false)
  minimumStockLevel Int?
  stock             Int          @default(0)
  unit              ProductUnit  @default(PCS)
  createdBy         String
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  category          Category?    @relation(fields: [categoryId], references: [id])
  user              User         @relation(fields: [createdBy], references: [id])
  orderItems        OrderItem[]
  stockIns          StockIn[]
  damages           Damage[]
}

enum OrderStatus {
  PENDING
  APPROVED
  REJECTED
  SHIPPED
  DELIVERED
  PAID
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHEQUE
  MOBILE_BANKING
}

model Order {
  id              String       @id @default(uuid())
  orderNumber     String       @unique
  status          OrderStatus  @default(PENDING)
  customerId      String
  totalAmount     Decimal      @db.Decimal(12, 2)
  notes           String?
  rejectionReason String?
  createdBy       String
  reviewedBy      String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  customer       Customer     @relation(fields: [customerId], references: [id])
  createdByUser  User         @relation("CreatedOrders", fields: [createdBy], references: [id])
  reviewedByUser User?        @relation("ReviewedOrders", fields: [reviewedBy], references: [id])
  items          OrderItem[]
  shipment       Shipment?
  payment        Payment?
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  productId   String
  productName String
  unitPrice   Decimal  @db.Decimal(12, 2)
  quantity    Int
  totalPrice  Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model Shipment {
  id            String    @id @default(uuid())
  orderId       String    @unique
  shippedBy     String
  shippedAt     DateTime  @default(now())
  deliveryNotes String?
  deliveredAt   DateTime?

  order         Order     @relation(fields: [orderId], references: [id])
  shippedByUser User      @relation(fields: [shippedBy], references: [id])
}

model Payment {
  id          String       @id @default(uuid())
  orderId     String       @unique
  amount      Decimal      @db.Decimal(12, 2)
  method      PaymentMethod
  reference   String?
  receivedBy  String
  receivedAt  DateTime     @default(now())
  notes       String?

  order          Order     @relation(fields: [orderId], references: [id])
  receivedByUser User      @relation(fields: [receivedBy], references: [id])
}

model StockIn {
  id        String   @id @default(uuid())
  productId String
  quantity  Int
  notes     String?
  createdBy String
  createdAt DateTime @default(now())

  product       Product @relation(fields: [productId], references: [id])
  createdByUser User    @relation(fields: [createdBy], references: [id])
}

model Damage {
  id          String   @id @default(uuid())
  productId   String
  quantity    Int
  reason      String
  notes       String?
  createdBy   String
  createdAt   DateTime @default(now())

  product       Product @relation(fields: [productId], references: [id])
  createdByUser User    @relation(fields: [createdBy], references: [id])
}
